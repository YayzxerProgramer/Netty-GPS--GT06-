# ============================================
# .gitignore para RompGPS
# ============================================

# ============================================
# Archivos de entorno y secretos
# ============================================
.env
.env.local
.env.*.local
*.env

# ============================================
# IDE
# ============================================
.idea/
*.iml
*.ipr
*.iws
.vscode/
*.swp
*.swo
*~

# ============================================
# Build outputs
# ============================================
target/
build/
dist/
*.class
*.jar
*.war
*.ear

# ============================================
# Maven
# ============================================
.mvn/
mvnw
mvnw.cmd

# ============================================
# Node / FrontEnd
# ============================================
node_modules/
npm-debug.log
yarn-error.log
pnpm-debug.log
FrontEnd/node_modules/
FrontEnd/dist/
FrontEnd/.vite/

# ============================================
# Docker
# ============================================
docker-compose.override.yml
*.log

# ============================================
# System files
# ============================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================
# Logs
# ============================================
logs/
*.log

# ============================================
# Database files (si se usan localmente)
# ============================================
*.db
*.sqlite
*.sqlite3
